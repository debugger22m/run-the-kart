ANTHROPIC_API_KEY=sk-ant-...

# Real event data — free tier at https://developer.ticketmaster.com (5,000 calls/day)
# Leave blank to use built-in mock events instead.
TICKETMASTER_API_KEY=

# Swap in when ready for other real APIs
# GOOGLE_MAPS_API_KEY=

# Fleet config
DEFAULT_FLEET_NAME=KartFleet
LOG_LEVEL=INFO

# Autonomous loop — how often the orchestrator runs (seconds)
LOOP_INTERVAL_SECONDS=10

# Demo mode — carts return to idle after this many seconds so you can
# watch autonomous reassignment in real time. Set to 0 to use real event end_time.
DEMO_EXPIRE_SECS=45
